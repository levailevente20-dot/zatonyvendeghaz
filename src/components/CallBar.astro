---
import { business } from '../data/site';
---

<a class="call-bar" href={business.phoneHref} aria-label={`Hívja a ${business.name}-at: ${business.phone}`}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
  </svg>
  <span>Hívjon most · {business.phone}</span>
</a>

<style>
  .call-bar {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 60;
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.6em;
    padding: 0.95rem 1rem calc(0.95rem + env(safe-area-inset-bottom));
    background: var(--terracotta-deep);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 -8px 24px -8px rgba(43, 38, 32, 0.35);
  }

  .call-bar svg {
    width: 1.2em;
    height: 1.2em;
  }

  @media (max-width: 800px) {
    .call-bar {
      display: flex;
    }
  }
</style>
