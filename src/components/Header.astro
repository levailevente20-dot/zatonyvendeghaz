---
import { Image } from 'astro:assets';
import { business, nav } from '../data/site';
import logo from '../assets/images/logo/logo-primary.png';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand">
      <Image src={logo} alt="Zátony Vendégház" width={52} height={52} loading="eager" />
      <span class="brand-text">
        <strong>Zátony</strong> Vendégház
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Menü megnyitása">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <nav class="main-nav" aria-label="Fő navigáció">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="btn btn-call header-call" href={business.phoneHref}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
      <span>{business.phone}</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 242, 232, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--sand-line);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.85rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
    margin-right: auto;
  }

  .brand :global(img) {
    border-radius: 999px;
  }

  .brand-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }

  .brand-text strong {
    font-weight: 700;
  }

  .main-nav ul {
    display: flex;
    align-items: center;
    gap: 1.9rem;
  }

  .main-nav a {
    text-decoration: none;
    font-weight: 500;
    font-size: 0.98rem;
    color: var(--ink-soft);
    padding-block: 0.3rem;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .main-nav a:hover,
  .main-nav a[aria-current='page'] {
    color: var(--terracotta-deep);
    border-color: var(--terracotta-deep);
  }

  .header-call span {
    display: inline;
  }

  .nav-toggle {
    display: none;
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    margin-inline: auto;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 800px) {
    .nav-burger {
      display: flex;
    }

    .header-call span {
      display: none;
    }

    .header-call {
      padding: 0.8em;
      border-radius: 999px;
    }

    .header-call svg {
      width: 1.3em;
      height: 1.3em;
      margin: 0;
    }

    .main-nav {
      position: fixed;
      inset: 0;
      top: 68px;
      background: var(--cream);
      padding: 1.5rem;
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .main-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }

    .main-nav a {
      display: block;
      padding: 0.9rem 0.25rem;
      font-size: 1.15rem;
      border-bottom: 1px solid var(--sand-line);
    }

    .nav-toggle:checked ~ .main-nav {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle:checked ~ .nav-burger span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
