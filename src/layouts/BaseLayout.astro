---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallBar from '../components/CallBar.astro';
import PartnerPopup from '../components/PartnerPopup.astro';
import Seo from '../components/Seo.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  hidePartnerPopup?: boolean;
}

const { title, description, path, image, hidePartnerPopup = false } = Astro.props;
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="theme-color" content="#d8a070" />
    <Seo title={title} description={description} path={path} image={image} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Ugrás a tartalomhoz</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CallBar />
    {!hidePartnerPopup && <PartnerPopup />}
    <script>
      const revealTargets = document.querySelectorAll('.reveal, .reveal-stagger');

      function revealAll() {
        revealTargets.forEach((el) => el.classList.add('is-visible'));
      }

      if ('IntersectionObserver' in window && revealTargets.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0, rootMargin: '0px 0px -10% 0px' }
        );

        revealTargets.forEach((el) => observer.observe(el));

        // Safety net: never let content stay invisible if something (fast
        // programmatic scroll, bfcache restore, browser quirk) misses the
        // intersection callback.
        window.setTimeout(revealAll, 4000);
      } else {
        revealAll();
      }
    </script>
  </body>
</html>
