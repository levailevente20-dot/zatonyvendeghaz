---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { business, nearby, nearbyIcons } from '../../data/site';

import heroImg from '../../assets/images/kornyek/termalstrand-medence.jpg';
import termalstrand from '../../assets/images/kornyek/termalstrand-medence.jpg';
import buffe from '../../assets/images/kornyek/kornyek-01.png';
import halaszcsarda from '../../assets/images/kornyek/kornyek-03.png';

const photoByTitle: Record<string, ImageMetadata> = {
  'Tiszacsegei Termálstrand': termalstrand
};
---

<BaseLayout
  title="Programok Tiszacsegén és környékén | Zátony Vendégház"
  description="Termálstrand, Tisza vízitúra, Hortobágy és helyi gasztronómia: minden, ami egy könnyű, élhető hétvégéhez kell Tiszacsegén, a Zátony Vendégház közelében."
  path="/programok/"
>
  <section class="page-hero">
    <Image src={heroImg} alt="Tiszacsegei Termálstrand" class="page-hero-img" loading="eager" fetchpriority="high" widths={[640, 960, 1280, 1920]} sizes="100vw" />
    <div class="page-hero-scrim"></div>
    <div class="container page-hero-content">
      <p class="eyebrow eyebrow--light">Tiszacsege és környéke</p>
      <h1>Programok a környéken</h1>
      <p class="hero-sub">Közel van minden, ami egy könnyű, élhető hétvégéhez kell.</p>
    </div>
  </section>

  {nearby.map((item, i) => (
    <section class={`section program-row ${i % 2 === 1 ? 'section--sand' : ''} reveal`}>
      <div class={`container program-grid ${i % 2 === 1 ? 'program-grid--reverse' : ''}`}>
        <div class="program-media">
          {photoByTitle[item.title] ? (
            <Image src={photoByTitle[item.title]} alt={item.title} width={720} height={560} loading="lazy" />
          ) : item.title === 'Helyi gasztronómia' ? (
            <div class="program-photo-pair">
              <div class="gasztro-photo gasztro-photo--featured">
                <span class="partner-badge">Ajánlott partnerünk</span>
                <Image src={buffe} alt="Tiszavirág Büfé kínálata" width={360} height={560} loading="lazy" />
              </div>
              <div class="gasztro-photo">
                <Image src={halaszcsarda} alt="Halászcsárda Tiszacsege kínálata" width={360} height={560} loading="lazy" />
              </div>
            </div>
          ) : (
            <div class="program-icon-panel">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={nearbyIcons[item.title]}></path>
              </svg>
            </div>
          )}
        </div>
        <div class="program-copy">
          <p class="eyebrow">{item.distance}</p>
          <h2>{item.title}</h2>
          <p class="lede">{item.long}</p>
        </div>
      </div>
    </section>
  ))}

  <CtaBand secondaryLabel="Kérdezzen tőlünk">
    Fedezze fel <span class="highlight">Tiszacsegét</span>, mi közben otthonra talál nálunk
  </CtaBand>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 56vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .page-hero :global(.page-hero-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 16, 10, 0.2) 0%, rgba(20, 16, 10, 0.85) 100%);
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    color: var(--white);
    padding-block: 3rem 3.5rem;
    max-width: 42rem;
  }

  .page-hero h1 {
    color: var(--white);
    margin-block: 0.3em 0.4em;
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.55), 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255, 253, 249, 0.92);
    max-width: 40ch;
    margin: 0;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
  }

  .program-row:first-of-type {
    padding-top: clamp(3.5rem, 6vw, 5.5rem);
  }

  .program-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .program-grid--reverse .program-media {
    order: 2;
  }

  .program-media :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lift);
  }

  .program-photo-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  .program-photo-pair :global(img) {
    aspect-ratio: 3 / 4;
  }

  .gasztro-photo {
    position: relative;
  }

  .gasztro-photo--featured {
    transform: translateY(-0.85rem);
  }

  .gasztro-photo .partner-badge {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 2;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(43, 38, 32, 0.72);
    backdrop-filter: blur(3px);
    padding: 0.35em 0.7em;
    border-radius: 999px;
  }

  .program-icon-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--terracotta), var(--sage));
    box-shadow: var(--shadow-lift);
  }

  .program-icon-panel svg {
    width: 30%;
    height: 30%;
    color: var(--white);
    opacity: 0.92;
  }

  .program-copy .eyebrow {
    color: var(--sage-deep);
  }

  .program-copy .lede {
    max-width: 52ch;
  }

  @media (max-width: 900px) {
    .program-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .program-grid--reverse .program-media {
      order: -1;
    }
  }
</style>
