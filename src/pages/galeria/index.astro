---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { business } from '../../data/site';

const kulterModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/kulter/*.{jpg,JPG}',
  { eager: true }
);
const belterModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/belter/*.{jpg,JPG}',
  { eager: true }
);
const rendezvenyModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/rendezveny/*.{jpg,JPG}',
  { eager: true }
);

type Item = { image: ImageMetadata; category: 'udvar' | 'szobak' | 'rendezvenyterem'; alt: string };

function toItems(modules: Record<string, { default: ImageMetadata }>, category: Item['category'], alt: string): Item[] {
  return Object.values(modules)
    .sort((a, b) => a.default.src.localeCompare(b.default.src))
    .map((m) => ({ image: m.default, category, alt }));
}

const items: Item[] = [
  ...toItems(kulterModules, 'udvar', 'Az udvar a Zátony Vendégházban'),
  ...toItems(belterModules, 'szobak', 'Szoba a Zátony Vendégházban'),
  ...toItems(rendezvenyModules, 'rendezvenyterem', 'A rendezvényterem')
];

const fullImages = await Promise.all(
  items.map((item) => getImage({ src: item.image, width: 1400, format: 'webp' }))
);

const filters = [
  { key: 'mind', label: 'Mind' },
  { key: 'udvar', label: 'Udvar' },
  { key: 'szobak', label: 'Szobák' },
  { key: 'rendezvenyterem', label: 'Rendezvényterem' }
];
---

<BaseLayout
  title="Galéria | Zátony Vendégház Tiszacsege"
  description="Nézze meg a Zátony Vendégház udvarát, szobáit és rendezvénytermét képekben. Tiszacsege, a Tisza-tó közelében."
  path="/galeria/"
>
  <section class="section gallery-intro reveal">
    <div class="container">
      <p class="eyebrow">Galéria</p>
      <h1>Nézzen körül nálunk</h1>
      <p class="lede">Válogatott képek az udvarról, a szobákról és a rendezvényteremről. Kattintson bármelyikre a nagyításhoz.</p>

      <div class="filters" role="tablist" aria-label="Galéria szűrők">
        {filters.map((filter, i) => (
          <button class="filter-chip" data-filter={filter.key} aria-pressed={i === 0 ? 'true' : 'false'}>
            {filter.label}
          </button>
        ))}
      </div>

      <div class="gallery-grid">
        {items.map((item, i) => (
          <button class="gallery-item" data-category={item.category} data-index={i} data-full={fullImages[i].src} aria-label={`${item.alt} megnyitása nagyobb méretben`}>
            <Image src={item.image} alt={item.alt} width={480} height={360} loading="lazy" widths={[300, 480, 800]} sizes="(max-width: 800px) 45vw, 22vw" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <CtaBand secondaryLabel="Írjon nekünk">
    Tetszik, amit lát? <span class="highlight">Foglaljon</span> még ma!
  </CtaBand>

  <div class="lightbox" id="lightbox" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Bezárás">&times;</button>
    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Előző kép">&#8249;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Következő kép">&#8250;</button>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const items = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-item'));

  const lightbox = document.getElementById('lightbox') as HTMLDivElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;

  let visibleItems: HTMLButtonElement[] = items;
  let currentIndex = 0;

  function applyFilter(filter: string) {
    for (const item of items) {
      const match = filter === 'mind' || item.dataset.category === filter;
      item.style.display = match ? '' : 'none';
    }
    visibleItems = items.filter((item) => item.style.display !== 'none');
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      applyFilter(chip.dataset.filter ?? 'mind');
    });
  });

  function openLightbox(item: HTMLButtonElement) {
    const img = item.querySelector('img') as HTMLImageElement;
    currentIndex = visibleItems.indexOf(item);
    lightboxImg.src = item.dataset.full ?? img.src;
    lightboxImg.alt = img.alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  function showAt(index: number) {
    if (!visibleItems.length) return;
    const wrapped = (index + visibleItems.length) % visibleItems.length;
    currentIndex = wrapped;
    const target = visibleItems[wrapped];
    const img = target.querySelector('img') as HTMLImageElement;
    lightboxImg.src = target.dataset.full ?? img.src;
    lightboxImg.alt = img.alt;
  }

  items.forEach((item) => item.addEventListener('click', () => openLightbox(item)));
  closeBtn.addEventListener('click', closeLightbox);
  prevBtn.addEventListener('click', () => showAt(currentIndex - 1));
  nextBtn.addEventListener('click', () => showAt(currentIndex + 1));

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') showAt(currentIndex + 1);
    if (e.key === 'ArrowLeft') showAt(currentIndex - 1);
  });
</script>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 2rem 0 2.5rem;
  }

  .filter-chip {
    border: 1px solid var(--sand-line);
    background: var(--white);
    color: var(--ink-soft);
    padding: 0.55em 1.2em;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .filter-chip[aria-pressed='true'] {
    background: var(--sage-deep);
    border-color: var(--sage-deep);
    color: var(--white);
  }

  .filter-chip:hover {
    border-color: var(--sage-deep);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
  }

  .gallery-item {
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    transition: box-shadow 0.3s ease;
  }

  .gallery-item:hover {
    box-shadow: 0 0 0 3px var(--cream), 0 0 22px 3px rgba(216, 160, 112, 0.5);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(20, 16, 10, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-img {
    max-width: min(90vw, 1100px);
    max-height: 85vh;
    width: auto;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lift);
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    font-size: 2.2rem;
    line-height: 1;
    background: none;
    border: none;
    color: var(--white);
    cursor: pointer;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 253, 249, 0.12);
    border: none;
    color: var(--white);
    font-size: 2.5rem;
    line-height: 1;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    cursor: pointer;
  }

  .lightbox-nav:hover {
    background: rgba(255, 253, 249, 0.25);
  }

  .lightbox-prev {
    left: 1rem;
  }

  .lightbox-next {
    right: 1rem;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lightbox-nav {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 2rem;
    }
  }
</style>
