---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business, web3formsAccessKey } from '../../data/site';
---

<BaseLayout
  title="Kapcsolat | Zátony Vendégház Tiszacsege"
  description="Hívja a Zátony Vendégházat, vagy kérjen visszahívást — Tiszacsege, Zátony VIII. u. 21. Telefon: +36 30 899 0982."
  path="/kapcsolat/"
>
  <section class="section contact-hero">
    <div class="container">
      <p class="eyebrow">Kapcsolat</p>
      <h1>Hívjon minket, vagy írjon pár sort</h1>
      <p class="lede">A leggyorsabb válasz telefonon várható, de ha szívesebben ír, a visszahívás-kérő űrlapon is elérhet minket.</p>
    </div>
  </section>

  <section class="section section--sand contact-grid-section reveal">
    <div class="container contact-grid">
      <div class="contact-info card">
        <h2>Elérhetőségek</h2>
        <ul class="info-list">
          <li>
            <span class="info-label">Telefon</span>
            <a class="info-value info-phone" href={business.phoneHref}>{business.phone}</a>
          </li>
          <li>
            <span class="info-label">E-mail</span>
            <a class="info-value" href={`mailto:${business.email}`}>{business.email}</a>
          </li>
          <li>
            <span class="info-label">Cím</span>
            <a class="info-value" href={business.mapsUrl} target="_blank" rel="noopener noreferrer">{business.address}</a>
          </li>
        </ul>
        <a class="btn btn-call btn-lg contact-call-btn" href={business.phoneHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <span>Hívjon most</span>
        </a>

        <div class="map-embed">
          <iframe
            src={business.mapsEmbedUrl}
            width="100%"
            height="260"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Zátony Vendégház térképen"
          ></iframe>
        </div>
      </div>

      <div class="contact-form-wrap card">
        <h2>Kérek visszahívást</h2>
        <p class="form-sub">Írja meg elérhetőségét, mi visszahívjuk.</p>

        <form id="callback-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={web3formsAccessKey} />
          <input type="hidden" name="subject" value="Új visszahívás-kérés — Zátony Vendégház weboldal" />
          <input type="checkbox" name="botcheck" class="visually-hidden" tabindex="-1" autocomplete="off" />

          <label>
            <span>Név</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>

          <label>
            <span>Telefonszám</span>
            <input type="tel" name="phone" required autocomplete="tel" />
          </label>

          <label>
            <span>Preferált időpont (nem kötelező)</span>
            <input type="text" name="preferred_dates" placeholder="pl. augusztus 10-12." />
          </label>

          <label>
            <span>Üzenet</span>
            <textarea name="message" rows="4" placeholder="Létszám, dátum, vagy bármi, amit tudnunk kell"></textarea>
          </label>

          <button type="submit" class="btn btn-call btn-lg form-submit">Visszahívást kérek</button>

          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>

          <p class="form-fallback">
            Vagy írjon közvetlenül: <a href={`mailto:${business.email}`}>{business.email}</a>
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('callback-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    const formData = new FormData(form);
    status.textContent = 'Küldés...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' }
      });
      const result = await response.json();

      if (result.success) {
        status.textContent = 'Köszönjük! Hamarosan visszahívjuk.';
        form.reset();
      } else {
        status.textContent = 'Hiba történt a küldés során — kérjük, hívjon minket telefonon.';
      }
    } catch {
      status.textContent = 'Hiba történt a küldés során — kérjük, hívjon minket telefonon.';
    }
  });
</script>

<style>
  .contact-hero {
    padding-bottom: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-info,
  .contact-form-wrap {
    padding: 2rem;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin: 1.5rem 0;
  }

  .info-label {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.2rem;
  }

  .info-value {
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .info-phone {
    font-size: 1.4rem;
    color: var(--terracotta-deep);
  }

  .contact-call-btn {
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .map-embed {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .map-embed iframe {
    display: block;
  }

  .form-sub {
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }

  #callback-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  #callback-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.92rem;
  }

  #callback-form input[type='text'],
  #callback-form input[type='tel'],
  #callback-form textarea {
    font: inherit;
    padding: 0.75em 0.9em;
    border: 1px solid var(--sand-line);
    border-radius: var(--radius-sm);
    background: var(--cream);
    color: var(--ink);
    resize: vertical;
  }

  #callback-form input:focus,
  #callback-form textarea:focus {
    outline: 2px solid var(--terracotta-deep);
    outline-offset: 1px;
  }

  .form-submit {
    margin-top: 0.5rem;
  }

  .form-status {
    min-height: 1.4em;
    font-weight: 600;
    color: var(--sage-deep);
    margin: 0;
  }

  .form-fallback {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 0;
  }

  .form-fallback a {
    color: var(--terracotta-deep);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
